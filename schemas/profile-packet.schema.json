{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://pkim.local/schemas/profile-packet.schema.json",
    "title": "ProfilePacket",
    "type": "object",
    "required": [
        "run_id",
        "record",
        "content",
        "classified_groups",
        "compared_records",
        "risk_level",
        "candidate_notes",
        "candidate_edges",
        "candidate_resolution_map",
    ],
    "properties": {
        "run_id": {"type": "string"},
        "record": {
            "type": "object",
            "required": ["pkim_id", "dt_uuid"],
            "properties": {
                "pkim_id": {"type": "string"},
                "dt_uuid": {"type": "string"},
            },
            "additionalProperties": true,
        },
        "content": {"type": "string"},
        "classified_groups": {"type": "array", "items": {"type": "object"}},
        "compared_records": {"type": "array", "items": {"type": "object"}},
        "classify_error": {"type": "string"},
        "compare_error": {"type": "string"},
        "suggested_name": {"type": "string"},
        "risk_level": {"type": "string"},
        "candidate_notes": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "candidate_id",
                    "candidate_fingerprint",
                    "order",
                    "title_hint",
                    "concept_summary",
                    "candidate_class",
                    "note_intent",
                    "source_anchors",
                    "dependency_type",
                    "dependency_targets",
                    "note_worthiness",
                    "graph_value",
                    "distinctness",
                    "cross_source_likelihood",
                    "defer_reason",
                    "proposed_existing_neighbours",
                    "risk_level",
                ],
                "properties": {
                    "candidate_id": {"type": "string"},
                    "candidate_fingerprint": {"type": "string"},
                    "order": {"type": "integer"},
                    "title_hint": {"type": "string"},
                    "concept_summary": {"type": "string"},
                    "candidate_class": {"type": "string"},
                    "note_intent": {"type": "string"},
                    "source_anchors": {"type": "array", "items": {"type": "object"}},
                    "dependency_type": {"type": "string"},
                    "dependency_targets": {
                        "type": "array",
                        "items": {"type": "string"},
                    },
                    "note_worthiness": {"type": "string"},
                    "graph_value": {"type": "string"},
                    "distinctness": {"type": "string"},
                    "cross_source_likelihood": {"type": "string"},
                    "defer_reason": {"type": "string"},
                    "proposed_existing_neighbours": {
                        "type": "array",
                        "items": {"type": "object"},
                    },
                    "risk_level": {"type": "string"},
                },
                "additionalProperties": true,
            },
        },
        "candidate_edges": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "edge_id",
                    "relation_type",
                    "rationale",
                    "confidence",
                    "source_anchors",
                    "materialisation_status",
                    "defer_reason",
                ],
                "properties": {
                    "edge_id": {"type": "string"},
                    "source_candidate_id": {"type": ["string", "null"]},
                    "source_note_ref": {"type": ["object", "null"]},
                    "target_candidate_id": {"type": ["string", "null"]},
                    "target_note_ref": {"type": ["object", "null"]},
                    "relation_type": {"type": "string"},
                    "rationale": {"type": "string"},
                    "confidence": {"type": "string"},
                    "source_anchors": {"type": "array", "items": {"type": "object"}},
                    "materialisation_status": {"type": "string"},
                    "defer_reason": {"type": "string"},
                },
                "additionalProperties": true,
            },
        },
        "candidate_resolution_map": {"type": "array", "items": {"type": "object"}},
        "knowledge_note_draft": {"type": "object"},
        "relation_candidates": {"type": "array", "items": {"type": "object"}},
    },
    "additionalProperties": true,
}
